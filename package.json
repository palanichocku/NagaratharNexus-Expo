{
  "name": "nagaratharnexus-expo",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "web:dev": "APP_ENV=dev npx expo start -c --web --port 8081",
    "web:prod": "APP_ENV=prod npx expo start -c --web --port 8082",
    "web:local": "APP_ENV=local  EXPO_NO_DOTENV=1 dotenv -e ./env/.env.localdev -- npx expo start -c --web --port 8083",
    "native:dev": "APP_ENV=dev EXPO_NO_DOTENV=1 dotenv -e ./env/.env.development -- npx expo start -c",
    "native:prod": "APP_ENV=prod  EXPO_NO_DOTENV=1 dotenv -e ./env/.env.production -- npx expo start -c",
    "native:local": "APP_ENV=local EXPO_NO_DOTENV=1 dotenv -e ./env/.env.localdev -- npx expo start -c",
    "env:sanity": "dotenv -e .env.test -- tsx scripts/env-sanity.ts",
    "db:reset": "supabase db reset",
    "seed:test": "dotenv -e .env.test -- tsx scripts/seed-test-data.ts",
    "test:functional": "dotenv -e .env.test -- vitest run tests/functional --reporter=verbose",
    "test:perf": "dotenv -e .env.test -- vitest run tests/perf --reporter=verbose",
    "test:runner": "dotenv -e .env.test -- tsx scripts/test-runner.ts",
    "seed:test-users": "dotenv -e .env.development -- tsx scripts/generate-test-users.ts",
    "delete:test-users": "dotenv -e .env.development -- tsx scripts/delete-test-users.ts",
    "cleanup:user": "dotenv -e .env.development -- tsx scripts/cleanup-user.ts",
    "seed:staff:dev": "dotenv -e .env.development -- node scripts/seed-staff.mjs",
    "seed:staff:prod": "dotenv -e .env.production -- node scripts/seed-staff.mjs",
    "seed:staff:local": "dotenv -e .env.localdev -- node scripts/seed-staff.mjs",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@ptomasroos/react-native-multi-slider": "^2.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@supabase/supabase-js": "^2.95.3",
    "country-state-city": "^3.2.1",
    "expo": "~54.0.33",
    "expo-blur": "~15.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-print": "~15.0.8",
    "expo-router": "~6.0.23",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-chart-kit": "^6.12.0",
    "react-native-element-dropdown": "^2.12.4",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@types/react": "~19.1.0",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "lighthouse": "^13.0.3",
    "pg": "^8.19.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.18"
  },
  "private": true
}
